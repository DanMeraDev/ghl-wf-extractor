{
  "manifest_version": 3,
  "name": "Extractor de Workflows GHL",
  "version": "1.1.0",
  "description": "Exporta los JSON de tus workflows de GoHighLevel: navega carpetas, eliges cuales y los descarga. Funciona en cualquier dominio de GHL.",
  "permissions": ["downloads", "storage", "scripting", "activeTab"],
  "host_permissions": ["https://*.leadconnectorhq.com/*"],
  "action": {
    "default_title": "Extractor de Workflows GHL",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://*.leadconnectorhq.com/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://*.leadconnectorhq.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED"
    }
  ]
}
